{
  "name": "roy-cell-ecommerce",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "server": "tsx server/src/index.ts",
    "start": "tsx server/src/index.ts",
    "build": "tsc && npm run check:server && vite build",
    "check:server": "tsc --noEmit --module ESNext --moduleResolution bundler --target ES2020 --esModuleInterop --skipLibCheck --strict server/src/index.ts api/[...path].ts",
    "preview": "vite preview --host 127.0.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.2.0",
    "mongoose": "^9.6.3",
    "multer": "^2.1.1",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0"
  }
}
